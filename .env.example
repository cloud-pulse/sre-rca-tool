# ─────────────────────────────────────────
# SYSTEM FLAGS
# ─────────────────────────────────────────

# SYSTEM_DEBUG=false
# Set to true to print all internal debug info
# including: pipeline steps, LLM prompts,
# raw LLM responses, RAG retrieval details,
# module load times, and error tracebacks.
# Usage: SYSTEM_DEBUG=true python main.py analyze

# SYSTEM_LOG_LEVEL=INFO
# Python logging level: DEBUG, INFO, WARN, ERROR
# Controls third-party library log verbosity.

# ─────────────────────────────────────────
# UI FLAGS
# ─────────────────────────────────────────

# UI_SUPPRESS_LOGS=true
# Set to true (default) to hide noisy startup
# logs from HuggingFace, transformers, ChromaDB.
# Set to false to see all library output.

# UI_RICH_OUTPUT=true
# Set to true for colored rich terminal UI.
# Set to false for plain text output only.

# UI_SHOW_TIMESTAMPS=true
# Show timestamps in watch mode output.

# ─────────────────────────────────────────
# LLM FLAGS
# ─────────────────────────────────────────

# LLM_CACHE_ENABLED=true
# Cache LLM responses by log content hash.
# Same log file = instant response, no LLM call.
# Cache stored in .llm_cache/ directory.

# LLM_CACHE_TTL_SECONDS=3600
# How long to keep cached responses (seconds).
# Default: 1 hour (3600).

# LLM_WARMUP_ON_START=true
# Send a tiny warmup prompt to Ollama when the
# app starts so the model is pre-loaded in memory
# before the main analysis call.
# Adds ~5s to startup but saves 30-60s on analysis.

# LLM_KEEP_ALIVE=true
# Keep Ollama model loaded between calls.
# Prevents cold-start delay on repeated runs.

# LLM_MAX_TOKENS=500
# Maximum tokens in LLM response.
# Lower = faster, less detail.
# Higher = slower, more detail.

# LLM_TIMEOUT_SECONDS=300
# Seconds before LLM call times out.

# ─────────────────────────────────────────
# SOURCE FLAGS
# ─────────────────────────────────────────

# SOURCE_KUBERNETES=false
# Set to true to fetch logs and pod metrics
# from a live Kubernetes cluster via kubectl.
# Set to false (default) to use local log files
# and mock resource data.
# Requires: kubectl configured + cluster running.

# SOURCE_NAMESPACE=default
# Kubernetes namespace to query when
# SOURCE_KUBERNETES=true.
# Example: SOURCE_NAMESPACE=sre-demo

# SOURCE_LOG_TAIL_LINES=100
# Number of log lines to fetch per pod
# when SOURCE_KUBERNETES=true.

# ─────────────────────────────────────────
# RAG FLAGS
# ─────────────────────────────────────────

# RAG_ENABLED=true
# Set to false to disable RAG entirely
# even when --mode rag is specified.

# RAG_TOP_K=3
# Number of historical incidents to retrieve.

# RAG_SIMILARITY_THRESHOLD=60
# Minimum similarity % to consider a match.